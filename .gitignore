# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in to committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# IDE - VS Code Local History
.history/
.trae/
.vscode/

# GitHub Actions 临时文件
.github/workflows/*.bak

# 构建时生成的图片（从 src/posts/images/ 复制）
/public/posts/images/

# Backup files
*.bak
package.json.bak

# Static export output (GitHub Pages)
/dist/
/SantaChains.github.io

# Personal development notes
/openmemory.md
/structDev.md
/design.md 

# assets
*.pdf
*.epub

# Jujutsu version control
.jj/

# Obsidian - 只保留配置，忽略个人状态
.obsidian/


__pycache__/

# Windows 系统文件
Thumbs.db
desktop.ini
Desktop.ini

# 临时文件
*.tmp
*.temp
*~

# 编辑器交换文件
*.swp
*.swo
*._*

# macOS 系统文件
.AppleDouble
.LSOverride
